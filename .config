# financebench_runner config: Llama 3B, temperature 0
# On macOS we use Ollama (SGLang server requires Linux). Server: ollama serve
model_id: "llama3.2:3b"
temperature: 0.0

# Optional: run only these 0-based example indices; omit to run all
example_indices: [12, 49, 100, 70, 68, 47, 125, 84, 63, 57, 20, 82, 58, 53, 9, 43, 18, 3, 27, 17, 72, 10, 31, 24, 76, 36, 14, 32, 74, 61, 6, 41, 88, 51]

sglang:
  base_url: "http://localhost:11434/v1"
  timeout_s: 120.0
  max_retries: 3

max_new_tokens: 512
top_p: 1.0
seed: 42

prompt_template: |
  Context:
  {context}

  Question:
  {query}

  Answer:
