# financebench_runner config: Llama 3B, temperature 0
# On macOS we use Ollama (SGLang server requires Linux). Server: ollama serve
model_id: "meta-llama/Llama-3.1-8B-Instruct"
temperature: 0.0

# Optional: run only these 0-based example indices; omit to run all
example_indices: [4, 11, 13, 19, 35, 42, 48, 69, 71, 73, 77, 83, 85, 86, 87, 97, 101, 102, 103, 105, 112, 113, 115, 117, 118, 119, 124, 145, 146, 147, 148, 149, 150]

sglang:
  base_url: "http://localhost:8000/v1"
  timeout_s: 120.0
  max_retries: 3

# Correctness evaluation (used with --correctness flag)
correctness_model: "gpt-4o"
correctness_tolerance: 0.10  # 10% numerical tolerance

max_new_tokens: 512
top_p: 1.0
seed: 42

prompt_template: |
  Context:
  {context}

  Question:
  {query}

  Answer:
